{
  "manifest_version": 3,
  "name": "YouTube No-Cookie Redirect",
  "version": "1.0.1",
  "description": "Reindirizza i video YouTube alla versione no-cookie, escludendo gli Shorts",
  "permissions": [
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://youtu.be/*",
    "https://www.yout-ube.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "YouTube No-Cookie Redirect",
    "default_popup": "popup.html",
    "default_icons": {
      "16": "images/icon-16.png",
      "48": "images/icon-48.png",
      "128": "images/icon-128.png"
    }
  },
  "icons": {
    "16": "images/icon-16.png",
    "48": "images/icon-48.png",
    "128": "images/icon-128.png"
  }
}
